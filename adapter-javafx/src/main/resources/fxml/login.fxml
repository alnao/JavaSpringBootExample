<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="it.alnao.springbootexample.javafx.controller.LoginController"
      spacing="15" alignment="CENTER" prefWidth="400" prefHeight="300"
      style="-fx-background-color: #f4f4f4; -fx-padding: 20;">

    <Label text="Gestione Annotazioni" 
           style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #333;"/>
    
    <Label text="Accedi al sistema" 
           style="-fx-font-size: 14px; -fx-text-fill: #666;"/>

    <VBox spacing="10" VBox.vgrow="ALWAYS">
        <padding>
            <Insets top="20" right="40" bottom="20" left="40"/>
        </padding>

        <Label text="Username:" style="-fx-font-weight: bold;"/>
        <TextField fx:id="usernameField" promptText="Inserisci username"/>

        <Label text="Password:" style="-fx-font-weight: bold;"/>
        <PasswordField fx:id="passwordField" promptText="Inserisci password"/>

        <Label fx:id="errorLabel" text="" 
               style="-fx-text-fill: red; -fx-font-size: 12px;"
               visible="false" wrapText="true"/>

        <HBox spacing="10" alignment="CENTER">
            <padding>
                <Insets top="10"/>
            </padding>
            
            <Button fx:id="loginButton" text="Accedi" 
                    onAction="#handleLogin" defaultButton="true"
                    style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 30;"/>
            
            <Button text="Esci" onAction="#handleCancel" cancelButton="true"
                    style="-fx-background-color: #f44336; -fx-text-fill: white; -fx-padding: 10 30;"/>
        </HBox>
    </VBox>

    <Label text="Credenziali di default: admin / password" 
           style="-fx-font-size: 11px; -fx-text-fill: #999; -fx-font-style: italic;"/>
</VBox>
