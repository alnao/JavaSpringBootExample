<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="it.alnao.springbootexample.javafx.controller.MainController"
            prefWidth="1024" prefHeight="768">

    <!-- Top Menu Bar -->
    <top>
        <VBox>
            <MenuBar>
                <Menu text="File">
                    <MenuItem text="Nuova Annotazione" onAction="#handleCrea"/>
                    <SeparatorMenuItem/>
                    <MenuItem text="Esci"/>
                </Menu>
                <Menu text="Modifica">
                    <MenuItem text="Modifica Selezionata" onAction="#handleModifica"/>
                    <MenuItem text="Elimina Selezionata" onAction="#handleElimina"/>
                </Menu>
                <Menu text="Visualizza">
                    <MenuItem text="Aggiorna" onAction="#handleRefresh"/>
                </Menu>
                <Menu text="Aiuto">
                    <MenuItem text="Informazioni"/>
                </Menu>
            </MenuBar>
            
            <!-- Toolbar -->
            <ToolBar>
                <Button fx:id="creaButton" text="Nuova" onAction="#handleCrea" 
                        style="-fx-background-color: #4CAF50; -fx-text-fill: white;"/>
                <Button fx:id="modificaButton" text="Modifica" onAction="#handleModifica"/>
                <Button fx:id="eliminaButton" text="Elimina" onAction="#handleElimina"
                        style="-fx-background-color: #f44336; -fx-text-fill: white;"/>
                <Separator orientation="VERTICAL"/>
                
                <Label text="Ricerca:"/>
                <TextField fx:id="searchField" promptText="Cerca..." prefWidth="200"/>
                <Button text="Cerca" onAction="#handleSearch"/>
                
                <Separator orientation="VERTICAL"/>
                
                <Label text="Stato:"/>
                <ComboBox fx:id="statoFilter" prefWidth="150"/>
                
                <Label text="Categoria:"/>
                <ComboBox fx:id="categoriaFilter" prefWidth="150"/>
                
                <Region HBox.hgrow="ALWAYS"/>
                
                <Label fx:id="currentUserLabel" text="Utente: " 
                       style="-fx-font-weight: bold;"/>
            </ToolBar>
        </VBox>
    </top>

    <!-- Center - Split Pane -->
    <center>
        <SplitPane dividerPositions="0.6" VBox.vgrow="ALWAYS">
            <!-- Left - Table -->
            <VBox spacing="5">
                <padding>
                    <Insets top="10" right="10" bottom="10" left="10"/>
                </padding>
                
                <Label text="Lista Annotazioni" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                
                <TableView fx:id="annotazioniTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="descrizioneColumn" text="Descrizione" prefWidth="200"/>
                        <TableColumn fx:id="statoColumn" text="Stato" prefWidth="100"/>
                        <TableColumn fx:id="categoriaColumn" text="Categoria" prefWidth="100"/>
                        <TableColumn fx:id="prioritaColumn" text="Priorità" prefWidth="70"/>
                        <TableColumn fx:id="utenteColumn" text="Utente" prefWidth="100"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>
            </VBox>

            <!-- Right - Detail Panel -->
            <VBox spacing="10">
                <padding>
                    <Insets top="10" right="10" bottom="10" left="10"/>
                </padding>
                
                <Label text="Dettaglio Annotazione" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
                    <VBox spacing="10">
                        <padding>
                            <Insets top="5" right="5" bottom="5" left="5"/>
                        </padding>
                        
                        <Label text="Valore Nota:" style="-fx-font-weight: bold;"/>
                        <TextArea fx:id="valoreNotaArea" prefRowCount="5" wrapText="true" 
                                  promptText="Inserisci il contenuto dell'annotazione..."/>
                        
                        <Label text="Descrizione:" style="-fx-font-weight: bold;"/>
                        <TextField fx:id="descrizioneField" promptText="Breve descrizione..."/>
                        
                        <HBox spacing="10">
                            <VBox spacing="5" HBox.hgrow="ALWAYS">
                                <Label text="Categoria:" style="-fx-font-weight: bold;"/>
                                <TextField fx:id="categoriaField" promptText="es. Lavoro, Personale..."/>
                            </VBox>
                            
                            <VBox spacing="5">
                                <Label text="Priorità:" style="-fx-font-weight: bold;"/>
                                <Spinner fx:id="prioritaSpinner" prefWidth="80" editable="true"/>
                            </VBox>
                        </HBox>
                        
                        <Label text="Stato:" style="-fx-font-weight: bold;"/>
                        <ComboBox fx:id="statoComboBox" prefWidth="200"/>
                        
                        <Label text="Tags:" style="-fx-font-weight: bold;"/>
                        <TextField fx:id="tagsField" promptText="tag1, tag2, tag3..."/>
                        
                        <CheckBox fx:id="pubblicaCheckBox" text="Annotazione pubblica"/>
                        
                        <Separator/>
                        
                        <HBox spacing="10" alignment="CENTER">
                            <Button fx:id="salvaButton" text="Salva" onAction="#handleSalva"
                                    style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-padding: 10 30;"/>
                            <Button fx:id="annullaButton" text="Annulla" onAction="#handleAnnulla"
                                    style="-fx-padding: 10 30;"/>
                        </HBox>
                    </VBox>
                </ScrollPane>
            </VBox>
        </SplitPane>
    </center>

    <!-- Bottom Status Bar -->
    <bottom>
        <HBox spacing="10" style="-fx-background-color: #e0e0e0; -fx-padding: 5;">
            <Label fx:id="statusLabel" text="Pronto" HBox.hgrow="ALWAYS"/>
        </HBox>
    </bottom>

</BorderPane>
